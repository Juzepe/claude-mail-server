# =============================================================================
# OpenDKIM configuration — Generated by mailserver installer
# Domain: {{DOMAIN}}
# =============================================================================

# --- Mode ---
# s = sign outgoing mail
# v = verify incoming signatures
Mode                    sv

# --- Socket ---
# Listen on localhost:8891 for Postfix milter connection
Socket                  inet:8891@localhost

# --- Logging ---
Syslog                  yes
SyslogSuccess           yes
LogWhy                  yes

# --- Signing settings ---
Canonicalization        relaxed/relaxed
SignatureAlgorithm      rsa-sha256

# --- Key and table files ---
KeyTable                /etc/opendkim/KeyTable
SigningTable            refile:/etc/opendkim/SigningTable
ExternalIgnoreList      /etc/opendkim/TrustedHosts
InternalHosts           /etc/opendkim/TrustedHosts

# --- Domain settings ---
Domain                  {{DOMAIN}}
Selector                mail

# --- Key file (fallback / single domain) ---
KeyFile                 /etc/opendkim/keys/{{DOMAIN}}/mail.private

# --- Other settings ---
# Don't sign messages from untrusted senders
OversignHeaders         From
SubDomains              no

# --- PID ---
PidFile                 /run/opendkim/opendkim.pid

# --- Run as ---
UserID                  opendkim:opendkim

# --- Required headers to sign ---
# Per RFC 6376, at minimum sign From, Subject, To, Date
SignHeaders             From,To,Cc,Subject,Date,Message-ID,MIME-Version,Content-Type
